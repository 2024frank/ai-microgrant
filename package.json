{
  "name": "ai-microgrant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --runInBand --ci",
    "setup": "cp -n .env.local.example .env.local 2>/dev/null || echo '.env.local already exists'; echo 'Fill in .env.local then run: mysql -h $DATABASE_HOST -u $DATABASE_USERNAME -p $DATABASE_NAME < schema.sql && npx tsx scripts/seed-admins.ts'",
    "db:schema": "node -e \"require('dotenv').config({path:'.env.local'}); const {execSync}=require('child_process'); execSync('mysql -h '+process.env.DATABASE_HOST+' -P '+process.env.DATABASE_PORT+' -u '+process.env.DATABASE_USERNAME+' -p'+process.env.DATABASE_PASSWORD+' '+process.env.DATABASE_NAME+' < schema.sql',{stdio:'inherit'})\"",
    "db:seed": "npx tsx scripts/seed-admins.ts",
    "ci": "npm run lint && npm run test:ci"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^1.16.0",
    "mysql2": "^3.22.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
