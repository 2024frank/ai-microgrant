{
  "name": "ai-microgrant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --runInBand --ci",
    "setup": "cp -n .env.example .env.local 2>/dev/null || echo '.env.local already exists'; echo 'Fill in .env.local then run: npm run db:migrate && npm run db:seed'",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:status": "tsx scripts/migrate.ts status",
    "db:dump-schema": "tsx scripts/dump-schema.ts",
    "db:schema": "tsx scripts/migrate.ts",
    "db:seed": "npx tsx scripts/seed-admins.ts",
    "events:revalidate": "tsx scripts/revalidate-pending-events.ts",
    "ci": "npm run lint && npm run test:ci"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "imapflow": "^1.4.6",
    "lucide-react": "^1.16.0",
    "mailparser": "^3.9.14",
    "mysql2": "^3.22.3",
    "next": "16.2.6",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/dotenv": "^6.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
