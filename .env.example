# Public application URL
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MySQL 8
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USERNAME=ai_microgrant
DATABASE_PASSWORD=replace-me
DATABASE_NAME=ai_microgrant

# Anthropic managed agents
ANTHROPIC_API_KEY=replace-me
SOURCE_BUILDER_ENVIRONMENT_ID=replace-me
SOURCE_BUILDER_VAULT_ID=replace-me
AGENT_RUN_TIMEOUT_MS=240000
AGENT_RUN_STALE_MINUTES=10
# Invalid output is repaired in-session; values above 2 are hard-capped.
AGENT_JSON_REPAIR_ATTEMPTS=1
EMAIL_MAX_PER_RUN=5
EMAIL_RUN_TIMEOUT_MS=240000

# Internal endpoint authentication — generate independent random values
CRON_SECRET=replace-with-a-long-random-value
INGEST_SECRET=replace-with-a-different-long-random-value
MEDIA_PROXY_SECRET=replace-with-a-third-independent-random-value

# CommunityHub submission identity
COMMUNITYHUB_EMAIL=calendar@example.org
ADMIN_EMAIL=admin@example.org

# Firebase web client
NEXT_PUBLIC_FIREBASE_API_KEY=replace-me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-me
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-me.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-me
NEXT_PUBLIC_FIREBASE_APP_ID=replace-me
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin service-account JSON, serialized onto one line
FIREBASE_SERVICE_ACCOUNT={}

# Outbound mail and optional IMAP ingestion
SMTP_HOST=smtp.example.org
SMTP_PORT=465
SMTP_USER=calendar@example.org
SMTP_PASS=replace-me
IMAP_HOST=imap.example.org
IMAP_PORT=993
NEXT_PUBLIC_SMTP_USER=calendar@example.org

# Optional transactional-email provider
RESEND_API_KEY=

# Optional source-specific integrations
APOLLO_VEEZI_SITE_TOKEN=
APOLLO_AGENT_ID=

# Setup endpoint is disabled unless both values are intentionally configured
SETUP_ENABLED=false
SETUP_SECRET=replace-with-another-random-value
